# 로컬 개발 환경 변수 (기본값)
# 실제 API 키는 .env.local에 저장됨 (.gitignore에 포함)

NODE_ENV=development

# Supabase (실제 값은 .env.local에)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase 브라우저 노출용 (실제 값은 .env.local에, SUPABASE_URL/SUPABASE_ANON_KEY와 동일)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Notion API (실제 값은 .env.local에)
NOTION_API_KEY=

# Notion DB IDs (실제 값은 .env.local에)
NOTION_INVOICE_DB_ID=
NOTION_ITEMS_DB_ID=
