# 환경 설정
NODE_ENV=development

# Vercel 배포 시 설정
# VERCEL_URL=your-vercel-url.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# ===== Supabase 설정 (필수) =====
# Supabase 프로젝트 설정에서 발급받은 값
# https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===== Notion API 설정 (필수) =====
# Notion 워크스페이스 설정에서 발급받은 값
# https://www.notion.so/my-integrations → 'Invoice Web' Integration
# ⚠️ 주의: 이 키는 서버에서만 사용 가능 (클라이언트 노출 금지)
NOTION_API_KEY=noti_your_notion_integration_token_here

# Notion 데이터베이스 ID (사용자가 설정한 후 추가)
# Notion DB 링크: https://notion.so/your-workspace/your-db-id
# ID 추출: URL에서 뒤의 32자리 문자 (하이픈 제외)
NOTION_CLIENTS_DB_ID=your_clients_database_id_here
NOTION_INVOICES_DB_ID=your_invoices_database_id_here
NOTION_TEMPLATES_DB_ID=your_templates_database_id_here

# ===== 선택사항 =====
# Claude Code Slack 통합 (선택사항)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
